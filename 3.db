CREATE TABLE STUDENT(SNUM INT PRIMARY KEY,SNAME VARCHAR2(20),MAJOR VARCHAR2(20),LEVEL1 VARCHAR2(2),AGE INT);

CREATE TABLE FACULTY(FID INT PRIMARY KEY,FNAME VARCHAR2(20),DEPTID INT);

CREATE TABLE CLASS(NAME VARCHAR2(20) PRIMARY KEY,MEETSAT VARCHAR2(10),ROOM VARCHAR2(10),D INT,FOREIGN KEY(D) REFERENCES FACULTY(FID));

CREATE TABLE ENROLLED(SNUM INT,CNAME VARCHAR2(20),PRIMARY KEY(SNUM,CNAME),FOREIGN KEY(SNUM) REFERENCES STUDENT(SNUM),FOREIGN KEY(CNAME) REFERENCES CLASS(NAME));

