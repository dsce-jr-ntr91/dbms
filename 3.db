SELECT DISTINCT S.SNAME FROM STUDENT S,CLASS C,ENROLLED E,FACULTY F WHERE S.SNUM=E.SNUM AND E.CNAME=C.NAME AND C.D=F.FID AND F.FNAME='Prof. Harshith' AND S.LEVEL1='JR';

SELECT DISTINCT C.NAME FROM CLASS C WHERE C.ROOM='R128' UNION SELECT E.CNAME FROM ENROLLED E GROUP BY E.CNAME HAVING COUNT(*)>=5;

SELECT DISTINCT F.FNAME FROM FACULTY F WHERE 5>(SELECT COUNT(E.SNUM) FROM CLASS C,ENROLLED E WHERE C.NAME=E.CNAME AND C.D=F.FID);