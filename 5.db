SELECT C.CNAME,COUNT(O.ONO) AS NO_OF_ORDERS,AVG(O.ORD_AMT) AS AVG_ORDER_AMT FROM CUSTOMER C,ORDERS O WHERE C.CID=O.CID GROUP BY C.CNAME;

SELECT S.ONO FROM SHIPMENT S,WAREHOUSE W WHERE S.WARENO=W.WARENO AND W.CITY='SYD';

DELETE FROM ITEM WHERE INO=10;

UPDATE ORDER_ITEM SET INO=NULL WHERE INO=10;